# Configuración de Firebase - Reemplaza estos valores con los de tu proyecto en Firebase
REACT_APP_FIREBASE_API_KEY=tu-api-key-aqui
REACT_APP_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=tu-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789012
REACT_APP_FIREBASE_APP_ID=1:123456789012:web:abc123def456
REACT_APP_FIREBASE_MEASUREMENT_ID=G-ABCDEFGHIJ

# URL del API Backend
REACT_APP_API_URL=http://localhost:5050/api
